-    ];
-    const longTasks = observeLongTasks();
-    const results: RoutingSegmentBenchmarkResult[] = [];
-    const measurementWindows: Array<{ startTime: number; endTime: number }> = [];
-
-    try {
-      for (let index = 0; index < warmed.segments.length; index += 1) {
-        onProgress?.({
-          phase: 'measure',
