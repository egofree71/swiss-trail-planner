-        observedLongTasks.length > 0 ? Math.max(...observedLongTasks) : null,
-      unexpectedNetworkCellLoads: results.reduce(
-        (sum, result) => sum + result.unexpectedNewCells,
-        0,
-      ),
-    };
-  } finally {
-    loader.dispose();
-  }
-}
