-          'deviceMemory' in navigator
-            ? (navigator as Navigator & { deviceMemory?: number }).deviceMemory ?? null
-            : null,
-      },
-      benchmark: currentReport,
-    },
-    `${scenarioFileBase(currentReport.scenario.name)}-benchmark.json`,
